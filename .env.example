# URL base do backend (Socket.IO/API).
VITE_API_URL=http://localhost:3000

# Habilita o modo mock local (somente em desenvolvimento).
# Valores aceitos: true | false
VITE_ENABLE_MOCK_MODE=false

# Firebase (planejado / roadmap)
# Status: ainda não utilizado em produção neste projeto; mantenha preenchido
# quando a integração real com Firebase Auth/Firestore for ativada.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
